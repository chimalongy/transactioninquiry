@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-20">
    <h1 class="text-4xl font-bold text-red-600 mb-4">Error</h1>
    <h2 class="text-xl text-gray-600 mb-4">An error occurred while processing your request.</h2>
    @if (Model.ShowRequestId)
    {
        <p class="text-sm text-gray-500">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }
    <a href="/Dashboard" class="mt-6 inline-block text-blue-600 hover:underline">Return to Dashboard</a>
</div>
