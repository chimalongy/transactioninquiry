@{
    ViewData["Title"] = "Update Password";
    Layout = null;
    string userName = ViewBag.UserName ?? "";
    string email = ViewBag.Email ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Password - Transaction Inquiry</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-surface min-h-screen flex flex-col font-body">

    <main class="flex-1 flex items-center justify-center px-4 py-10">
        <div class="w-full max-w-md">

            @* Title block *@
            <div class="text-center mb-8">
                <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-amber-500" fill="none" stroke="currentColor"
                         stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94
                        a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                    </svg>
                </div>
                <h1 class="font-display text-text-primary text-xl font-semibold mb-1">
                    Password Change Required
                </h1>
                <p class="text-text-secondary text-sm mt-2 max-w-xs mx-auto">
                    You're using a temporary password. Please set a personal password before continuing.
                </p>
                <div class="accent-divider"></div>
            </div>

            @* Card *@
            <div class="bg-surface-card border border-border rounded-2xl px-8 py-8 shadow-sm">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-error-bg border border-error-border text-error text-sm rounded-lg px-4 py-3 mb-5">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form asp-controller="Auth" asp-action="UpdatePassword" method="post">
                    @Html.AntiForgeryToken()

                    @* Email - read-only display *@
                    <div class="mb-4">
                        <label class="block text-xs text-text-secondary font-medium mb-1.5 tracking-wide">
                            Email
                        </label>
                        <input type="text"
                               value="@email"
                               readonly
                               class="field-input field-input-readonly" />
                    </div>

                    @* Current (temporary) Password *@
                    <div class="mb-4">
                        <label class="block text-xs text-text-secondary font-medium mb-1.5 tracking-wide">
                            Current (temporary) password
                        </label>
                        <div class="relative">
                            <input type="password"
                                   name="oldPassword"
                                   id="oldPasswordInput"
                                   placeholder="Enter your temporary password"
                                   required
                                   class="field-input field-input-password" />
                            <button type="button" class="btn-eye"
                                    onclick="toggleField('oldPasswordInput','eye0a','eye0b')"
                                    aria-label="Toggle password visibility">
                                <svg id="eye0a" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                                <svg id="eye0b" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    @* New Password *@
                    <div class="mb-4">
                        <label class="block text-xs text-text-secondary font-medium mb-1.5 tracking-wide">
                            New password
                        </label>
                        <div class="relative">
                            <input type="password"
                                   name="newPassword"
                                   id="newPasswordInput"
                                   placeholder="At least 8 characters"
                                   required
                                   class="field-input field-input-password" />
                            <button type="button" class="btn-eye"
                                    onclick="toggleField('newPasswordInput','eye1a','eye1b')"
                                    aria-label="Toggle password visibility">
                                <svg id="eye1a" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                                <svg id="eye1b" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    @* Confirm Password *@
                    <div class="mb-6">
                        <label class="block text-xs text-text-secondary font-medium mb-1.5 tracking-wide">
                            Confirm new password
                        </label>
                        <div class="relative">
                            <input type="password"
                                   name="confirmPassword"
                                   id="confirmPasswordInput"
                                   placeholder="Repeat your new password"
                                   required
                                   class="field-input field-input-password" />
                            <button type="button" class="btn-eye"
                                    onclick="toggleField('confirmPasswordInput','eye2a','eye2b')"
                                    aria-label="Toggle password visibility">
                                <svg id="eye2a" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                                <svg id="eye2b" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit btn-submit-accent">
                        Set New Password
                    </button>
                </form>
            </div>

            <p class="text-center text-text-muted text-xs mt-6">
                &copy; 2026 Transaction Inquiry System
            </p>
        </div>
    </main>

    <script>
            function toggleField(inputId, openIconId, closeIconId) {
                const input = document.getElementById(inputId);
                const isHidden = input.type === 'password';
                input.type = isHidden ? 'text' : 'password';
                document.getElementById(openIconId).classList.toggle('hidden', isHidden);
                document.getElementById(closeIconId).classList.toggle('hidden', !isHidden);
            }
    </script>

</body>
</html>
