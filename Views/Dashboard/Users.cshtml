@{
    ViewData["Title"] = "Users";
    ViewData["ActivePage"] = "Users";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(24px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .fade-up   { opacity: 0; animation: fadeUp 0.45s ease forwards; }
    .fade-up-1 { animation-delay: 0.05s; }
    .fade-up-2 { animation-delay: 0.15s; }
    .spinner   { animation: spin 0.7s linear infinite; }

    .user-row { transition: background 0.12s ease; }
    .user-row:hover { background: var(--color-surface, #f8fafc); }

    /* ── Badges — mirrors audit log system ── */
    .badge {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 11px; font-weight: 600;
        padding: 4px 10px; border-radius: 20px; white-space: nowrap;
    }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    .badge-enabled  { background: #dcfce7; color: #15803d; }
    .badge-enabled  .badge-dot { background: #16a34a; }
    .badge-disabled { background: #fee2e2; color: #b91c1c; }
    .badge-disabled .badge-dot { background: #dc2626; }
    .badge-admin    { background: #dbeafe; color: #1d4ed8; }
    .badge-admin    .badge-dot { background: #2563eb; }
    .badge-user     { background: #f1f5f9; color: #475569; }
    .badge-user     .badge-dot { background: #94a3b8; }

    /* ── Account avatar — mirrors audit log ── */
    .account-avatar {
        width: 30px; height: 30px; border-radius: 50%;
        background: #ede9fe; color: #6d28d9;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 600; flex-shrink: 0;
    }

    /* ── Privilege pills ── */
    .priv-pill {
        display: inline-flex; align-items: center;
        font-size: 10px; font-weight: 600;
        padding: 2px 8px; border-radius: 20px;
        background: #ede9fe; color: #6d28d9;
        border: 1px solid #ddd6fe;
    }

    /* ── Modals ── */
    #userModal, #confirmModal, #viewModal {
        display: none;
        animation: fadeIn 0.2s ease forwards;
    }
    #userModal.open, #confirmModal.open, #viewModal.open { display: flex; }
    #modalBox, #confirmBox, #viewModalBox {
        animation: slideUp 0.26s cubic-bezier(0.34, 1.3, 0.64, 1) forwards;
    }

    /* ── View modal ── */
    .view-field-label  { font-size: 11px; color: var(--color-text-muted); margin-bottom: 3px; }
    .view-field-value  { font-size: 13px; color: var(--color-text-primary); }
    .view-field-empty  { font-size: 13px; color: var(--color-text-muted); font-style: italic; }
    .view-section-label {
        font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 10px;
    }
    .view-divider { height: 1px; background: var(--color-border, #e5e7eb); }
    .view-pill {
        font-size: 11px; padding: 2px 9px; border-radius: 20px;
        background: #ede9fe; border: 1px solid #ddd6fe; color: #6d28d9;
    }
    .view-ts-box {
        background: var(--color-surface, #f8fafc);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 12px; padding: 12px 14px;
    }
    .view-ts-label {
        font-size: 10px; font-weight: 600; letter-spacing: 0.07em;
        text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 2px;
    }
    .view-ts-value { font-size: 12px; color: var(--color-text-secondary); }
</style>

@* ── Page header ── *@
<div class="flex items-center justify-between mb-6 fade-up fade-up-1">
    <div>
        <h1 class="text-text-primary text-2xl font-semibold font-display">Users</h1>
        <p class="text-text-muted text-sm mt-0.5">Manage system users and their access privileges.</p>
    </div>
    <button onclick="openAddModal()"
            class="flex items-center gap-2 px-4 py-2.5 bg-accent-500 hover:bg-accent-600
                   text-white text-sm font-medium rounded-xl transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M12 5v14M5 12h14"/>
        </svg>
        Add User
    </button>
</div>

@* ── Alert area ── *@
<div id="alertArea" class="hidden mb-4"></div>

@* ── Users table card ── *@
<div class="bg-surface-card border border-border rounded-2xl shadow-sm overflow-hidden fade-up fade-up-2">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border bg-surface">
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Account</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Type</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide hidden md:table-cell">Privileges</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Status</th>
                    <th class="text-right text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody id="usersTableBody">
                <tr>
                    <td colspan="5" class="text-center py-14 text-text-muted">
                        <svg class="w-5 h-5 mx-auto mb-2 spinner text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                        </svg>
                        <span class="text-xs">Loading users...</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="px-6 py-3.5 border-t border-border bg-surface flex items-center justify-between">
        <span id="userCount" class="text-xs text-text-muted">--</span>
        <span class="text-xs text-text-muted">Transaction Inquiry — Users</span>
    </div>
</div>

@* ══════════════ VIEW USER MODAL ══════════════ *@
<div id="viewModal"
     class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm items-center justify-center px-4">
    <div id="viewModalBox"
         class="bg-surface-card border border-border rounded-2xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">

        @* Hero *@
        <div class="bg-surface border-b border-border px-6 py-5">
            <div class="flex items-start gap-3.5">
                <div id="viewAvatar" class="account-avatar text-base w-10 h-10 flex-shrink-0"></div>
                <div class="flex-1 min-w-0 pt-0.5">
                    <p id="viewUserName" class="text-text-primary font-semibold text-base leading-snug mb-0.5"></p>
                    <p id="viewEmail" class="text-text-muted text-xs mb-2.5"></p>
                    <div class="flex items-center gap-2 flex-wrap">
                        <span id="viewTypeBadge" class="badge"></span>
                        <span id="viewStatusBadge" class="badge"></span>
                    </div>
                </div>
                <button onclick="closeViewModal()"
                        class="flex-shrink-0 w-7 h-7 flex items-center justify-center
                               rounded-lg bg-surface-card border border-border
                               text-text-muted hover:text-text-primary transition-colors mt-0.5">
                    <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="w-3 h-3">
                        <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="px-6 py-5 space-y-5">
            <div>
                <p class="view-section-label">Account Details</p>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="view-field-label">First Name</p>
                        <p id="viewFirstName" class="view-field-value"></p>
                    </div>
                    <div>
                        <p class="view-field-label">Last Name</p>
                        <p id="viewLastName" class="view-field-value"></p>
                    </div>
                </div>
            </div>

            <div class="view-divider"></div>

            <div>
                <p class="view-section-label">Privileges</p>
                <div id="viewPrivileges" class="flex flex-wrap gap-1.5 mt-1"></div>
            </div>

            <div class="view-divider"></div>

            <div>
                <p class="view-section-label">Activity</p>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="view-field-label">Last Login IP</p>
                        <p id="viewLastLoginIP" class="view-field-value font-mono text-xs"></p>
                    </div>
                    <div>
                        <p class="view-field-label">Account Status</p>
                        <p id="viewStatusText" class="view-field-value"></p>
                    </div>
                </div>
            </div>

            <div class="view-ts-box">
                <p class="view-ts-label">Created</p>
                <p id="viewCreatedAt" class="view-ts-value"></p>
            </div>
        </div>

        <div class="px-6 py-4 border-t border-border flex justify-end gap-2.5">
            <button onclick="closeViewModal()"
                    class="px-4 py-2 text-sm text-text-secondary hover:text-text-primary
                           border border-border rounded-xl transition-colors">
                Close
            </button>
            <button id="viewEditBtn"
                    class="flex items-center gap-2 px-5 py-2 bg-accent-500 hover:bg-accent-600
                           text-white text-sm font-medium rounded-xl transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit User
            </button>
        </div>
    </div>
</div>

@* ══════════════ ADD / EDIT USER MODAL ══════════════ *@
<div id="userModal"
     class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm items-center justify-center px-4">
    <div id="modalBox"
         class="bg-surface-card border border-border rounded-2xl shadow-xl w-full max-w-md">

        <div class="flex items-center justify-between px-6 py-4 border-b border-border">
            <h2 id="modalTitle" class="text-text-primary font-semibold text-base">Add New User</h2>
            <button onclick="closeAddModal()"
                    class="w-7 h-7 flex items-center justify-center rounded-lg
                           text-text-muted hover:text-text-primary hover:bg-surface transition-colors">
                <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="w-4 h-4">
                    <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="px-6 py-5 space-y-4">
            <div id="modalAlert" class="hidden"></div>
            <input type="hidden" id="editUserId" value="" />

            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="text-xs font-medium text-text-secondary block mb-1">First Name *</label>
                    <input id="newFirstName" type="text" placeholder="John"
                           class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                                  text-text-primary placeholder-text-muted focus:outline-none
                                  focus:border-brand-400 focus:ring-2 focus:ring-brand-100 transition-colors" />
                </div>
                <div>
                    <label class="text-xs font-medium text-text-secondary block mb-1">Last Name *</label>
                    <input id="newLastName" type="text" placeholder="Doe"
                           class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                                  text-text-primary placeholder-text-muted focus:outline-none
                                  focus:border-brand-400 focus:ring-2 focus:ring-brand-100 transition-colors" />
                </div>
            </div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Email Address *</label>
                <input id="newEmail" type="email" placeholder="john.doe@company.com"
                       class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                              text-text-primary placeholder-text-muted focus:outline-none
                              focus:border-brand-400 focus:ring-2 focus:ring-brand-100 transition-colors" />
            </div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Account Type</label>
                <select id="newAccountType"
                        class="w-full px-3 py-2.5 bg-surface border border-border rounded-xl text-sm
                               text-text-primary focus:outline-none focus:border-brand-400
                               focus:ring-2 focus:ring-brand-100 transition-colors">
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            <div>
                <label class="text-xs font-medium text-text-secondary block mb-1">Privileges</label>
                <div class="space-y-2 bg-surface rounded-xl px-3 py-3 border border-border">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" id="privAll" value="ALL"
                               class="w-4 h-4 rounded border-border text-brand-500 focus:ring-brand-500" />
                        <span class="text-sm text-text-secondary">All Privileges</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" id="privView" value="VIEW"
                               class="w-4 h-4 rounded border-border text-brand-500 focus:ring-brand-500" />
                        <span class="text-sm text-text-secondary">View Reports</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" id="privManage" value="MANAGE"
                               class="w-4 h-4 rounded border-border text-brand-500 focus:ring-brand-500" />
                        <span class="text-sm text-text-secondary">Manage Users</span>
                    </label>
                </div>
            </div>

            <div class="flex items-center gap-2 bg-surface rounded-xl px-3 py-2.5 border border-border">
                <svg class="w-4 h-4 text-text-muted flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <span class="text-xs text-text-muted">Password will be set from the system default.</span>
            </div>
        </div>

        <div class="px-6 py-4 border-t border-border flex justify-end gap-3">
            <button onclick="closeAddModal()"
                    class="px-4 py-2 text-sm text-text-secondary hover:text-text-primary
                           border border-border rounded-xl transition-colors">
                Cancel
            </button>
            <button id="saveUserBtn" onclick="saveUser()"
                    class="px-5 py-2 bg-accent-500 hover:bg-accent-600 text-white
                           text-sm font-medium rounded-xl transition-colors flex items-center gap-2">
                <span id="saveBtnText">Create User</span>
                <svg id="saveBtnSpinner" class="hidden w-4 h-4 spinner" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                </svg>
            </button>
        </div>
    </div>
</div>

@* ══════════════ CONFIRM MODAL ══════════════ *@
<div id="confirmModal"
     class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm items-center justify-center px-4">
    <div id="confirmBox"
         class="bg-surface-card border border-border rounded-2xl shadow-xl w-full max-w-sm px-6 py-6">
        <div id="confirmIcon" class="w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-4"></div>
        <h3 id="confirmTitle" class="text-text-primary font-semibold text-base text-center mb-1"></h3>
        <p id="confirmMessage" class="text-text-muted text-sm text-center mb-5"></p>
        <div class="flex gap-3">
            <button onclick="closeConfirm()"
                    class="flex-1 py-2 text-sm text-text-secondary border border-border rounded-xl hover:bg-surface transition-colors">
                Cancel
            </button>
            <button id="confirmActionBtn"
                    class="flex-1 py-2 text-sm text-brand-500 font-medium bg-accent-500  rounded-xl ">
                Confirm
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var allUsers = [];
    var isEditing = false;

    // ── Helpers ──────────────────────────────────────────────────────────

    function initials(firstName, lastName) {
        var f = (firstName || '').trim();
        var l = (lastName  || '').trim();
        if (f && l) return (f[0] + l[0]).toUpperCase();
        if (f)      return f[0].toUpperCase();
        return 'U';
    }

    function formatDate(d) {
        if (!d) return '--';
        return new Date(d).toLocaleString('en-GB', {
            day: '2-digit', month: 'short', year: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
    }

    function escHtml(str) {
        return String(str || '')
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // ── Data ─────────────────────────────────────────────────────────────

    async function loadData() {
        try {
            var res = await fetch('/Dashboard/Users/GetAll');
            if (!res.ok) throw new Error('Failed to fetch users');
            allUsers = await res.json();
            renderTable(allUsers);
        } catch (err) {
            document.getElementById('usersTableBody').innerHTML =
                '<tr><td colspan="5" class="text-center py-14 text-text-muted text-xs">' +
                'Failed to load users. Please refresh the page.' +
                '</td></tr>';
        }
    }

    // ── Table ─────────────────────────────────────────────────────────────

    function renderTable(users) {
        var tbody   = document.getElementById('usersTableBody');
        var countEl = document.getElementById('userCount');

        countEl.textContent = users.length + ' user' + (users.length !== 1 ? 's' : '') + ' total';

        if (!users.length) {
            tbody.innerHTML =
                '<tr><td colspan="5" class="text-center py-14 text-text-muted text-xs">' +
                'No users found. Add one to get started.' +
                '</td></tr>';
            return;
        }

        var rows = '';
        for (var i = 0; i < users.length; i++) {
            var u           = users[i];
            var isDisabled  = (u.accountStatus || '').toLowerCase() === 'disabled';
            var isAdmin     = (u.accountType   || '').toLowerCase() === 'admin';
            var init        = initials(u.firstName, u.lastName);
            var fullName    = ((u.firstName || '') + ' ' + (u.lastName || '')).trim() || '--';

            // Privilege pills
            var privHtml = '';
            if (u.privileges && u.privileges.trim()) {
                var parts = u.privileges.split(',');
                for (var j = 0; j < parts.length; j++) {
                    var p = parts[j].trim();
                    if (p) privHtml += '<span class="priv-pill">' + escHtml(p) + '</span> ';
                }
            } else {
                privHtml = '<span class="text-xs text-text-muted">None</span>';
            }

            rows +=
                '<tr class="user-row border-b border-border last:border-0" id="row-' + u.id + '">' +

                    '<td class="px-6 py-5">' +
                        '<div class="flex items-center gap-2.5">' +
                            '<span class="account-avatar">' + escHtml(init) + '</span>' +
                            '<div>' +
                                '<p class="text-text-primary text-xs font-medium leading-snug">' + escHtml(fullName) + '</p>' +
                                '<p class="text-text-muted text-xs">' + escHtml(u.email || '--') + '</p>' +
                            '</div>' +
                        '</div>' +
                    '</td>' +

                    '<td class="px-6 py-5">' +
                        '<span class="badge ' + (isAdmin ? 'badge-admin' : 'badge-user') + '">' +
                            '<span class="badge-dot"></span>' +
                            escHtml(u.accountType || 'User') +
                        '</span>' +
                    '</td>' +

                    '<td class="px-6 py-5 hidden md:table-cell">' + privHtml + '</td>' +

                    '<td class="px-6 py-5">' +
                        '<span class="badge ' + (isDisabled ? 'badge-disabled' : 'badge-enabled') + '">' +
                            '<span class="badge-dot"></span>' +
                            (isDisabled ? 'Disabled' : 'Enabled') +
                        '</span>' +
                    '</td>' +

                    '<td class="px-6 py-5 text-right">' +
                        '<div class="flex items-center justify-end gap-1.5">' +
                            '<button onclick="openViewModal(' + u.id + ')" title="View user" ' +
                                'class="text-xs px-3 py-1.5 rounded-lg border border-border ' +
                                'text-text-secondary hover:bg-surface transition-colors">View</button>' +
                            '<button onclick="openEditModal(' + u.id + ')" title="Edit user" ' +
                                'class="text-xs px-3 py-1.5 rounded-lg border border-brand-200 ' +
                                'text-brand-600 hover:bg-brand-50 transition-colors">Edit</button>' +
                            '<button onclick="confirmDisable(' + u.id + ', ' + isDisabled + ')" ' +
                                'class="text-xs px-3 py-1.5 rounded-lg border transition-colors ' +
                                (isDisabled
                                    ? 'border-brand-200 text-brand-600 hover:bg-brand-50'
                                    : 'border-border text-text-secondary hover:border-amber-300 hover:text-amber-600 hover:bg-amber-50') + '">' +
                                (isDisabled ? 'Enable' : 'Disable') + '</button>' +
                            '<button onclick="confirmDelete(' + u.id + ', \'' + escHtml(fullName) + '\')" ' +
                                'class="text-xs px-3 py-1.5 rounded-lg border border-border ' +
                                'text-text-secondary hover:border-red-300 hover:text-red-600 ' +
                                'hover:bg-red-50 transition-colors">Delete</button>' +
                        '</div>' +
                    '</td>' +
                '</tr>';
        }
        tbody.innerHTML = rows;
    }

    // ── View modal ────────────────────────────────────────────────────────

    function openViewModal(id) {
        var u = null;
        for (var i = 0; i < allUsers.length; i++) {
            if (allUsers[i].id === id) { u = allUsers[i]; break; }
        }
        if (!u) return;

        var isDisabled = (u.accountStatus || '').toLowerCase() === 'disabled';
        var isAdmin    = (u.accountType   || '').toLowerCase() === 'admin';
        var fullName   = ((u.firstName || '') + ' ' + (u.lastName || '')).trim() || '--';
        var init       = initials(u.firstName, u.lastName);

        document.getElementById('viewAvatar').textContent = init;
        document.getElementById('viewUserName').textContent = fullName;
        document.getElementById('viewEmail').textContent = u.email || '';

        var typeBadge = document.getElementById('viewTypeBadge');
        typeBadge.className = 'badge ' + (isAdmin ? 'badge-admin' : 'badge-user');
        typeBadge.innerHTML = '<span class="badge-dot"></span>' + escHtml(u.accountType || 'User');

        var statusBadge = document.getElementById('viewStatusBadge');
        statusBadge.className = 'badge ' + (isDisabled ? 'badge-disabled' : 'badge-enabled');
        statusBadge.innerHTML = '<span class="badge-dot"></span>' + (isDisabled ? 'Disabled' : 'Enabled');

        document.getElementById('viewFirstName').textContent = u.firstName || '--';
        document.getElementById('viewLastName').textContent  = u.lastName  || '--';

        var privsEl = document.getElementById('viewPrivileges');
        if (u.privileges && u.privileges.trim()) {
            var parts = u.privileges.split(',');
            var pills = '';
            for (var j = 0; j < parts.length; j++) {
                var p = parts[j].trim();
                if (p) pills += '<span class="view-pill">' + escHtml(p) + '</span>';
            }
            privsEl.innerHTML = pills;
        } else {
            privsEl.innerHTML = '<span class="view-field-empty text-xs">No privileges assigned</span>';
        }

        document.getElementById('viewLastLoginIP').textContent = u.lastLoginIP || '—';

        var statusTextEl = document.getElementById('viewStatusText');
        statusTextEl.textContent  = isDisabled ? 'Disabled' : 'Active';
        statusTextEl.className    = 'view-field-value ' + (isDisabled ? 'text-red-500' : 'text-green-600');

        document.getElementById('viewCreatedAt').textContent = formatDate(u.createdAt);

        document.getElementById('viewEditBtn').onclick = function () {
            closeViewModal();
            openEditModal(id);
        };

        document.getElementById('viewModal').classList.add('open');
    }

    function closeViewModal() {
        document.getElementById('viewModal').classList.remove('open');
    }

    // ── Add / Edit modal ──────────────────────────────────────────────────

    function openAddModal() {
        isEditing = false;
        document.getElementById('modalTitle').textContent    = 'Add New User';
        document.getElementById('saveBtnText').textContent   = 'Create User';
        document.getElementById('editUserId').value          = '';
        document.getElementById('newFirstName').value        = '';
        document.getElementById('newLastName').value         = '';
        document.getElementById('newEmail').value            = '';
        document.getElementById('newEmail').disabled         = false;
        document.getElementById('newAccountType').value      = 'User';
        document.getElementById('privAll').checked           = false;
        document.getElementById('privView').checked          = false;
        document.getElementById('privManage').checked        = false;
        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('userModal').classList.add('open');
        document.getElementById('newFirstName').focus();
    }

    function openEditModal(userId) {
        var u = null;
        for (var i = 0; i < allUsers.length; i++) {
            if (allUsers[i].id === userId) { u = allUsers[i]; break; }
        }
        if (!u) return;

        isEditing = true;
        document.getElementById('modalTitle').textContent    = 'Edit User';
        document.getElementById('saveBtnText').textContent   = 'Save Changes';
        document.getElementById('editUserId').value          = u.id;
        document.getElementById('newFirstName').value        = u.firstName || '';
        document.getElementById('newLastName').value         = u.lastName  || '';
        document.getElementById('newEmail').value            = u.email     || '';
        document.getElementById('newEmail').disabled         = true;
        document.getElementById('newAccountType').value      = u.accountType || 'User';

        var privs = (u.privileges || '').toUpperCase();
        document.getElementById('privAll').checked    = privs.indexOf('ALL')    !== -1;
        document.getElementById('privView').checked   = privs.indexOf('VIEW')   !== -1 || privs.indexOf('ALL') !== -1;
        document.getElementById('privManage').checked = privs.indexOf('MANAGE') !== -1 || privs.indexOf('ALL') !== -1;

        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('userModal').classList.add('open');
    }

    function closeAddModal() {
        document.getElementById('userModal').classList.remove('open');
    }

    function getSelectedPrivileges() {
        var privs = [];
        if (document.getElementById('privAll').checked)    privs.push('ALL');
        if (document.getElementById('privView').checked)   privs.push('VIEW');
        if (document.getElementById('privManage').checked) privs.push('MANAGE');
        return privs.join(',');
    }

    async function saveUser() {
        var id          = document.getElementById('editUserId').value;
        var firstName   = document.getElementById('newFirstName').value.trim();
        var lastName    = document.getElementById('newLastName').value.trim();
        var email       = document.getElementById('newEmail').value.trim();
        var accountType = document.getElementById('newAccountType').value;
        var privileges  = getSelectedPrivileges();

        if (!firstName) { showModalAlert('First name is required.', 'error'); return; }
        if (!lastName)  { showModalAlert('Last name is required.',  'error'); return; }
        if (!email)     { showModalAlert('Email is required.',      'error'); return; }

        var btn     = document.getElementById('saveUserBtn');
        var spinner = document.getElementById('saveBtnSpinner');
        var btnText = document.getElementById('saveBtnText');
        btn.disabled = true;
        spinner.classList.remove('hidden');
        btnText.textContent = isEditing ? 'Saving...' : 'Creating...';

        try {
            var url = isEditing
                ? '/Dashboard/Users/Update/' + id
                : '/Dashboard/Users/Create';

            var res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ firstName: firstName, lastName: lastName, email: email, accountType: accountType, privileges: privileges })
            });

            var data = await res.json();
            if (!res.ok) throw new Error(data.message || (isEditing ? 'Failed to update user' : 'Failed to create user'));

            if (isEditing) {
                for (var i = 0; i < allUsers.length; i++) {
                    if (allUsers[i].id === parseInt(id)) { allUsers[i] = data; break; }
                }
            } else {
                allUsers.unshift(data);
            }

            renderTable(allUsers);
            closeAddModal();
            showAlert('User ' + (isEditing ? 'updated' : 'created') + ' successfully.', 'success');
        } catch (err) {
            showModalAlert(err.message || (isEditing ? 'Failed to update user.' : 'Failed to create user.'), 'error');
        } finally {
            btn.disabled = false;
            spinner.classList.add('hidden');
            btnText.textContent = isEditing ? 'Save Changes' : 'Create User';
        }
    }

    // ── Confirm modal ─────────────────────────────────────────────────────

    function openConfirm(opts) {
        document.getElementById('confirmIcon').className =
            'w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-4 ' + opts.iconBg;
        document.getElementById('confirmIcon').innerHTML = opts.icon;
        document.getElementById('confirmTitle').textContent   = opts.title;
        document.getElementById('confirmMessage').textContent = opts.message;

        var btn = document.getElementById('confirmActionBtn');
        btn.className = 'flex-1 py-2 text-sm font-medium text-white rounded-xl bg-accent-500 ' + opts.btnColor;
        btn.onclick   = opts.action;

        document.getElementById('confirmModal').classList.add('open');
    }

    function closeConfirm() {
        document.getElementById('confirmModal').classList.remove('open');
    }

    function confirmDelete(userId, name) {
        openConfirm({
            icon: '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">' +
                  '<polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>' +
                  '<path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>',
            iconBg:   'bg-red-50',
            title:    'Delete User',
            message:  'Are you sure you want to permanently delete ' + name + '? This action cannot be undone.',
            btnColor: 'bg-red-500 hover:bg-red-600',
            action:   function () { deleteUser(userId); }
        });
    }

    async function deleteUser(userId) {
        closeConfirm();
        try {
            var res = await fetch('/Dashboard/Users/Delete/' + userId, { method: 'POST' });
            if (!res.ok) throw new Error();
            document.getElementById('row-' + userId)?.remove();
            allUsers = allUsers.filter(function (u) { return u.id !== userId; });
            document.getElementById('userCount').textContent =
                allUsers.length + ' user' + (allUsers.length !== 1 ? 's' : '') + ' total';
            showAlert('User deleted successfully.', 'success');
        } catch {
            showAlert('Failed to delete user. Please try again.', 'error');
        }
    }

    function confirmDisable(userId, isCurrentlyDisabled) {
        var action = isCurrentlyDisabled ? 'enable' : 'disable';
        var user   = null;
        for (var i = 0; i < allUsers.length; i++) {
            if (allUsers[i].id === userId) { user = allUsers[i]; break; }
        }
        var name = user ? (user.firstName + ' ' + user.lastName).trim() : 'this user';

        openConfirm({
            icon: '<svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">' +
                  '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>' +
                  '<line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
            iconBg:   'bg-amber-50',
            title:    (isCurrentlyDisabled ? 'Enable' : 'Disable') + ' User',
            message:  'Are you sure you want to ' + action + ' ' + name + '?',
            btnColor: 'bg-amber-500 hover:bg-amber-600',
            action:   function () { toggleDisable(userId, isCurrentlyDisabled); }
        });
    }

    async function toggleDisable(userId, isCurrentlyDisabled) {
        closeConfirm();
        var newStatus = isCurrentlyDisabled ? 'enabled' : 'disabled';
        try {
            var res = await fetch('/Dashboard/Users/UpdateStatus/' + userId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            if (!res.ok) throw new Error();
            for (var i = 0; i < allUsers.length; i++) {
                if (allUsers[i].id === userId) { allUsers[i].accountStatus = newStatus; break; }
            }
            renderTable(allUsers);
            showAlert('User ' + newStatus + ' successfully.', 'success');
        } catch {
            showAlert('Failed to update user status. Please try again.', 'error');
        }
    }

    // ── Alert ─────────────────────────────────────────────────────────────

    function showAlert(message, type) {
        var el        = document.getElementById('alertArea');
        var isSuccess = type === 'success';
        el.className  = 'mb-4 px-4 py-3 rounded-xl text-sm border flex items-center gap-2 ' +
            (isSuccess ? 'bg-green-50 text-green-700 border-green-200' : 'bg-red-50 text-red-700 border-red-200');
        el.innerHTML  =
            '<svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">' +
            (isSuccess
                ? '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>'
                : '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>') +
            '</svg>' + escHtml(message);
        el.classList.remove('hidden');
        setTimeout(function () { el.classList.add('hidden'); }, 4000);
    }

    function showModalAlert(message, type) {
        var el       = document.getElementById('modalAlert');
        el.className = 'mb-1 px-3 py-2 rounded-xl text-xs border ' +
            (type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-green-50 text-green-700 border-green-200');
        el.textContent = message;
        el.classList.remove('hidden');
    }

    // ── Event listeners ───────────────────────────────────────────────────

    document.getElementById('viewModal').addEventListener('click', function (e) {
        if (e.target === this) closeViewModal();
    });
    document.getElementById('userModal').addEventListener('click', function (e) {
        if (e.target === this) closeAddModal();
    });
    document.getElementById('confirmModal').addEventListener('click', function (e) {
        if (e.target === this) closeConfirm();
    });

    ['newFirstName', 'newLastName', 'newEmail'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('keydown', function (e) { if (e.key === 'Enter') saveUser(); });
    });

    loadData();
</script>
}
