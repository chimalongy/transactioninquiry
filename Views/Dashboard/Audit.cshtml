@{
    ViewData["Title"] = "Audit Logs";
    ViewData["ActivePage"] = "Audit";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .fade-up   { opacity: 0; animation: fadeUp 0.45s ease forwards; }
    .fade-up-1 { animation-delay: 0.05s; }
    .fade-up-2 { animation-delay: 0.15s; }
    .spinner   { animation: spin 0.7s linear infinite; }

    .audit-row { transition: background 0.12s ease; }
    .audit-row:hover { background: var(--color-surface, #f8fafc); }

    .badge {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 11px; font-weight: 600;
        padding: 4px 10px; border-radius: 20px; white-space: nowrap;
    }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    .action-login    { background: #dcfce7; color: #15803d; }
    .action-login    .badge-dot { background: #16a34a; }
    .action-logout   { background: #f3f4f6; color: #6b7280; }
    .action-logout   .badge-dot { background: #9ca3af; }
    .action-create   { background: #dbeafe; color: #1d4ed8; }
    .action-create   .badge-dot { background: #2563eb; }
    .action-update   { background: #fef3c7; color: #b45309; }
    .action-update   .badge-dot { background: #d97706; }
    .action-delete   { background: #fee2e2; color: #b91c1c; }
    .action-delete   .badge-dot { background: #dc2626; }
    .action-password { background: #ede9fe; color: #6d28d9; }
    .action-password .badge-dot { background: #7c3aed; }
    .action-default  { background: #f1f5f9; color: #475569; }
    .action-default  .badge-dot { background: #94a3b8; }

    .account-avatar {
        width: 30px; height: 30px; border-radius: 50%;
        background: #dbeafe; color: #1d4ed8;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 600; flex-shrink: 0;
    }
</style>

@* ── Page header ── *@
<div class="flex items-center justify-between mb-6 fade-up fade-up-1">
    <div>
        <h1 class="text-text-primary text-2xl font-semibold font-display">Audit Logs</h1>
        <p class="text-text-muted text-sm mt-0.5">Track system activity and user actions.</p>
    </div>
</div>

@* ── Audit logs table card ── *@
<div class="bg-surface-card border border-border rounded-2xl shadow-sm overflow-hidden fade-up fade-up-2">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border bg-surface">
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Account</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Action</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide hidden md:table-cell">Description</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide hidden sm:table-cell">IP Address</th>
                    <th class="text-left text-xs font-semibold text-text-muted px-6 py-4 uppercase tracking-wide">Time</th>
                </tr>
            </thead>
            <tbody id="auditTableBody">
                <tr>
                    <td colspan="5" class="text-center py-14 text-text-muted">
                        <svg class="w-5 h-5 mx-auto mb-2 spinner text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                        </svg>
                        <span class="text-xs">Loading audit logs...</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="px-6 py-3.5 border-t border-border bg-surface flex items-center justify-between">
        <span id="auditCount" class="text-xs text-text-muted">--</span>
        <span class="text-xs text-text-muted">Transaction Inquiry — Audit Logs</span>
    </div>
</div>

@section Scripts {
<script>
    function getActionClass(action) {
        if (!action) return 'action-default';
        var a = action.toUpperCase();
        if (a.indexOf('LOGIN') !== -1 && a.indexOf('LOGOUT') === -1) return 'action-login';
        if (a.indexOf('LOGOUT')   !== -1) return 'action-logout';
        if (a.indexOf('CREATE')   !== -1) return 'action-create';
        if (a.indexOf('UPDATE')   !== -1) return 'action-update';
        if (a.indexOf('DELETE')   !== -1) return 'action-delete';
        if (a.indexOf('PASSWORD') !== -1) return 'action-password';
        return 'action-default';
    }

    function initials(email) {
        var atSign  = '@@';
        var name    = (email || '').split(atSign)[0];
        var parts   = name.split('.');
        return parts.length >= 2
            ? (parts[0][0] + parts[1][0]).toUpperCase()
            : (name[0] || 'U').toUpperCase();
    }

    function formatTime(t) {
        if (!t) return '--';
        var d    = new Date(t);
        var now  = new Date();
        var diff = Math.floor((now - d) / 1000);
        if (diff < 60)    return 'Just now';
        if (diff < 3600)  return Math.floor(diff / 60) + 'm ago';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
        return d.toLocaleDateString('en-GB', {
            day: '2-digit', month: 'short', year: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
    }

    async function loadAuditLogs() {
        try {
            var res = await fetch('/Dashboard/Audit/GetAll');
            if (!res.ok) throw new Error('Failed to fetch');
            renderTable(await res.json());
        } catch (err) {
            document.getElementById('auditTableBody').innerHTML =
                '<tr><td colspan="5" class="text-center py-14 text-text-muted text-xs">' +
                'Failed to load audit logs. Please refresh the page.' +
                '</td></tr>';
        }
    }

    function renderTable(logs) {
        var tbody   = document.getElementById('auditTableBody');
        var countEl = document.getElementById('auditCount');

        countEl.textContent = logs.length + ' log' + (logs.length !== 1 ? 's' : '') + ' total';

        if (!logs.length) {
            tbody.innerHTML =
                '<tr><td colspan="5" class="text-center py-14 text-text-muted text-xs">' +
                'No audit logs found.' +
                '</td></tr>';
            return;
        }

        var rows = '';
        for (var i = 0; i < logs.length; i++) {
            var log         = logs[i];
            var actionClass = getActionClass(log.action);
            var init        = initials(log.account);

            rows +=
                '<tr class="audit-row border-b border-border last:border-0">' +
                    '<td class="px-6 py-5">' +
                        '<div class="flex items-center gap-2.5">' +
                            '<span class="account-avatar">' + escHtml(init) + '</span>' +
                            '<span class="text-text-primary text-xs font-medium">' + escHtml(log.account || '--') + '</span>' +
                        '</div>' +
                    '</td>' +
                    '<td class="px-6 py-5">' +
                        '<span class="badge ' + actionClass + '">' +
                            '<span class="badge-dot"></span>' +
                            escHtml(log.action || '--') +
                        '</span>' +
                    '</td>' +
                    '<td class="px-6 py-5 text-text-secondary text-xs hidden md:table-cell">' +
                        escHtml(log.description || '--') +
                    '</td>' +
                    '<td class="px-6 py-5 text-text-muted text-xs font-mono hidden sm:table-cell">' +
                        escHtml(log.ipAddress || '--') +
                    '</td>' +
                    '<td class="px-6 py-5 text-text-muted text-xs whitespace-nowrap">' +
                        escHtml(formatTime(log.time)) +
                    '</td>' +
                '</tr>';
        }
        tbody.innerHTML = rows;
    }

    function escHtml(str) {
        return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    loadAuditLogs();
</script>
}